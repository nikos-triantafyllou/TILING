# Discrete Time embedding - Sionusoidal
class SinousoidalEmbedding(nn.Module):
    def __init__(self, emb_dim: int):
        super().__init__()
        self.mlp = nn.Sequential(
            nn.Linear(emb_dim, emb_dim * 4),
            nn.SiLU(),
            nn.Linear(emb_dim * 4, emb_dim*4) 
        )

    def forward(self, t: torch.Tensor):
        """
        t: (N,) timesteps (int or float)
        returns: (N, emb_dim)
        """
        # sinusoidal embedding
        half_dim = self.mlp[0].in_features // 2
        device = t.device
        freqs = torch.exp(
            -math.log(10_000.0) * torch.arange(0, half_dim, device=device).float() / (half_dim -1)
        )
        args = t[:, None].float() * freqs[None, :]
        emb = torch.cat([torch.sin(args), torch.cos(args)], dim=-1)
        return self.mlp(emb)
    

# Continuous Time embedding - Same as Legin+2024
class GaussianFourierProjection(nn.Module):
    """Gaussian Fourier embeddings for noise levels."""
    def __init__(self, emb_dim=64, scale=16.0):
        super().__init__()
        self.W = nn.Parameter(torch.randn(emb_dim) * scale, requires_grad=False)
        # Combine with the linear layers here - same as Legin without initializations and with output divided by 4 for injection to Unet here
        self.mlp = nn.Sequential(
        nn.Linear(2 * emb_dim, 4 * emb_dim),
        nn.SiLU(),
        nn.Linear(4 * emb_dim, 4*emb_dim) # Here output size was *4
        )

    def forward(self, x): # x is sigma
        x = torch.log(x)
        x_proj = x[:, None] * self.W[None, :] * 2 * np.pi
        emb = torch.cat([torch.sin(x_proj), torch.cos(x_proj)], dim=-1)
        return self.mlp(emb) # Combine with the linear layers here
    
class FourierFeatureEmbedding(nn.Module):
    def __init__(
        self,
        base_dim,   # 128
        scale=16.0, # 16  (see the paper in https://arxiv.org/pdf/2011.13456)
    ):
        super().__init__()

        # randomly sampled b
        # (no learnable parameters, but it must be saved !)
        self.b = nn.Parameter(
            torch.randn(base_dim) * scale,
            requires_grad=False
        )

    def forward(self, t):
        t_log = torch.log(t) # (apply as uniform-log variables)
        out = t_log[:, None] * self.b[None, :] # shape: [batch_size, base_dim]
        out = out * 2 * math.pi                # shape: [batch_size, base_dim]
        out = torch.cat([
            torch.sin(out),
            torch.cos(out)
        ], dim=-1)                             # shape: [batch_size, base_dim*2]
        return out
    


