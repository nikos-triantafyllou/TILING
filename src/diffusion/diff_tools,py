#  Euler-Maruyama sampling ------------------------------------------

def run_inference(unet, x_0, cond, beta_min, beta_max, eps, N, device, ICs_NGPE='None', ema = None):
    """
    Run Euler-Maruyama sampling for the given UNet model.
    Inputs:
    - unet: the trained UNet model
    - x_0: initial noise tensor (shape: [batch_size, channels, D
        , H, W])
    - cond: conditioning tensor (shape: [batch_size, cond_channels, D, H, W])
    - beta_min: minimum beta value for SDE
    - beta_max: maximum beta value for SDE
    - eps: small value to avoid numerical issues
    - N: number of diffusion steps
    Returns:
    - x: generated samples (shape: [batch_size, channels, D, H,
        W])
    """

    unet.eval()

    t_steps = torch.linspace(1.0, 0.0, N).to(device) * (1.0 - eps) + eps
    x = x_0
    b = x_0.size(dim=0)
    if ema is not None:
        with torch.no_grad(), ema.average_parameters():
            # (showing progress, because it needs a lot of time.)
            # for i, t in tqdm(enumerate(t_steps), total=N):
            print("Sampling...", flush = True)
            for i, t in enumerate(t_steps):
                model_out = unet(x, t.repeat(b), cond)
                beta_t = beta_min + (beta_max - beta_min) * t
                z = torch.randn_like(x).to(device)
                if i == N-1:
                    x = x + (beta_t / N) * (0.5 * x + model_out)
                else:
                    x = x + (beta_t / N) * (0.5 * x + model_out) + torch.sqrt(beta_t / N) * z
    else:
        with torch.no_grad():
            # (showing progress, because it needs a lot of time.)
            # for i, t in tqdm(enumerate(t_steps), total=N):
            print("Sampling...", flush = True)
            for i, t in enumerate(t_steps):
                model_out = unet(x, t.repeat(b), cond)
                beta_t = beta_min + (beta_max - beta_min) * t
                z = torch.randn_like(x).to(device)
                if i == N-1:
                    x = x + (beta_t / N) * (0.5 * x + model_out)
                else:
                    x = x + (beta_t / N) * (0.5 * x + model_out) + torch.sqrt(beta_t / N) * z

    # clip
#     x = torch.clamp(x, min=0.0, max=1.0)
    # if ICs_NGPE=='residual_whole':
    #     return x + cond[:, -1, :, :, :]  # add back the mean if normalized
    # else:
    return x 






