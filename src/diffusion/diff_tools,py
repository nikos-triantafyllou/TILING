def plot_test_all(box_length, x_0, x, cond, return08=False): 

    x_inferred = x.detach().cpu().numpy()[0, 0]  # shape (D,H,W)
    cond_np = cond.detach().cpu().numpy()[0]       # shape (2,D,H,W)
    # ----------------------------------------------------
    # Plotting (slices through the 3D field)
    # ----------------------------------------------------
    slice_idx = box_length // 2


    extent = [0, box_length*1.5, 0 , box_length*1.5]
    fig, axs = plt.subplots(2, 4, figsize=(12, 6))
    axs[0,0].imshow(cond_np[0, slice_idx], cmap='viridis', extent=extent)
    axs[0,0].set_title("21cm")
    if cond_np.shape[0]>1:
        axs[0,1].imshow(cond_np[1, slice_idx], cmap='viridis', extent=extent)
        axs[0,1].set_title("Galaxies")
    axs[0,2].imshow(x_inferred[slice_idx], cmap='viridis', extent=extent, vmin=-3, vmax=3 )
    axs[0,2].set_title("Inferred ICs")
    axs[0,3].imshow(x_0[0,0, slice_idx].to('cpu'), cmap='viridis', extent=extent, vmin=-3, vmax=3)
    axs[0,3].set_title("True ICs")
    for i in range(4):
        axs[0,i].set_xlabel('x axis [Mpc]')
    axs[0,0].set_ylabel('y axis [Mpc]')

    plt.tight_layout()
    
    
    
    bins=np.linspace(-5,5,100)
    x_inferred = x.detach().cpu().numpy()[0, 0]  # shape (D,H,W)
    axs[1,0].hist(x_inferred.flatten(), bins=bins, alpha=0.3, label='inferred');
    axs[1,0].hist(x_0[0,0,:,:,:].to('cpu').flatten(), bins=bins, alpha=0.3, label='true');
    axs[1,0].legend(loc = 'lower left');


    
    import powerbox as pbox
    pk1, k1 = pbox.get_power(x_inferred,box_length*1.5, log_bins=False)
    pk2, k2 = pbox.get_power(x_0[0,0,:,:,:].to('cpu'), box_length*1.5, log_bins=False)
    axs[1,1].loglog(k1,pk1, label='inferred')
    axs[1,1].loglog(k2,pk2, label='true')
    axs[1,1].legend(loc = 'lower left')
    
    
    pk, k = pbox.get_power(deltax= x_inferred, boxlength = box_length*1.5, deltax2 = x_0[0,0,:,:,:].to('cpu'), log_bins=False)
    pk = pk/np.sqrt(pk1*pk2)
    axs[1,2].plot(k,pk)
    axs[1,2].set_xscale('log')
    pk = np.nan_to_num(pk)
    k80 = k[np.argmin(abs(pk - 0.8))]
    axs[1,2].axvline(k80, color='black', linestyle='--', alpha=0.5)
    axs[1,2].text(0.9, 0.8,f'0.8 at {round(k80,2)}')

    if return08:
        return fig, k80
    else: 
        return fig













